# BlueStack environment overrides — copy to .env and edit as needed.

# Elastic Stack version (kept in sync across all three services)
STACK_VERSION=8.13.4

# Host port bindings (loopback-only by default)
ES_PORT=9200
KIBANA_PORT=5601
LS_LOGHOUND_PORT=5001
LS_NETSENTINEL_PORT=5002
LS_HONEYNET_PORT=5003
LS_THREATPULSE_PORT=5004

# JVM heap sizing — tune to your host
ES_HEAP=1g
LS_HEAP=512m
